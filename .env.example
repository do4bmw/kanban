DATABASE_URL=postgresql://kanban:password@localhost:5432/kanban
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_random_secret_min_32_chars

# SMTP (optional — wenn leer, werden Einladungslinks nur angezeigt)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Kanban <noreply@yourdomain.de>

# Branding (optional)
NEXT_PUBLIC_APP_NAME=Kanban
NEXT_PUBLIC_LOGO_URL=

# Fälligkeits-Erinnerungen (optional)
# Sichert den /api/cron/due-reminders Endpoint ab.
# Cron-Job auf dem Server: */30 * * * * curl -s -X POST -H "Authorization: Bearer $CRON_SECRET" https://yourdomain/api/cron/due-reminders
CRON_SECRET=
